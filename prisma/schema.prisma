generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int      @id @default(autoincrement())
  clerkId          String   @unique @map("clerk_id")
  email            String   @unique
  firstName        String   @map("first_name")
  lastName         String   @map("last_name")
  profileImageUrl  String?  @map("profile_image_url")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  handledTrips     Trip[]        @relation("TripHandler")
  tripMemberships  TripMember[]
  tripMessages     TripMessage[]
  sentRequests     TripRequest[] @relation("RequestSender")
  receivedRequests TripRequest[] @relation("RequestReceiver")
  notifications    Notification[]
  expenses         Expense[]
  expenseSplits    ExpenseSplit[]
  uploadedPhotos   TripPhoto[]

  @@map("users")
  @@index([clerkId])
  @@index([email])
}

model Trip {
  id                 String     @id @default(cuid())
  name               String
  description        String?
  startDate          DateTime?  @map("start_date")
  endDate            DateTime?  @map("end_date")
  startingPoint      String?    @map("starting_point")
  status             TripStatus @default(PLANNED)
  handlerClerkId     String     @map("handler_clerk_id")
  inviteCode         String     @unique @map("invite_code")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")
  isScrapbookPublic  Boolean    @default(false) @map("is_scrapbook_public")
  scrapbookShareLink String?    @unique @map("scrapbook_share_link")

  // ✅ CASCADE so deleting a handler user can delete their trips (and cascades further via tripId relations)
  handler   User @relation("TripHandler", fields: [handlerClerkId], references: [clerkId], onDelete: Cascade)

  members   TripMember[]
  messages  TripMessage[]
  requests  TripRequest[]
  expenses  Expense[]
  photos    TripPhoto[]

  @@map("trips")
  @@index([handlerClerkId])
  @@index([inviteCode])
}

model TripMember {
  id          String     @id @default(cuid())
  tripId      String     @map("trip_id")
  userClerkId String     @map("user_clerk_id")
  role        UserRole   @default(MEMBER)
  joinedAt    DateTime   @default(now()) @map("joined_at")
  joinMethod  JoinMethod @default(UNKNOWN) @map("join_method")
  joinDetails String?    @map("join_details")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  // ✅ CASCADE
  user User @relation(fields: [userClerkId], references: [clerkId], onDelete: Cascade)

  @@unique([tripId, userClerkId])
  @@map("trip_members")
  @@index([tripId])
  @@index([userClerkId])
}

model TripMessage {
  id          String   @id @default(cuid())
  tripId      String   @map("trip_id")
  userClerkId String   @map("user_clerk_id")
  message     String
  createdAt   DateTime @default(now()) @map("created_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  // ✅ CASCADE
  user User @relation(fields: [userClerkId], references: [clerkId], onDelete: Cascade)

  @@map("trip_messages")
  @@index([tripId])
  @@index([createdAt])
}

model TripRequest {
  id               String        @id @default(cuid())
  tripId            String       @map("trip_id")
  requesterClerkId  String       @map("requester_clerk_id")
  receiverClerkId   String       @map("receiver_clerk_id")
  status            RequestStatus @default(PENDING)
  message           String?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  // ✅ CASCADE
  requester User @relation("RequestSender", fields: [requesterClerkId], references: [clerkId], onDelete: Cascade)
  receiver  User @relation("RequestReceiver", fields: [receiverClerkId], references: [clerkId], onDelete: Cascade)

  @@unique([tripId, requesterClerkId])
  @@map("trip_requests")
  @@index([tripId])
  @@index([requesterClerkId])
  @@index([receiverClerkId])
  @@index([status])
}

model Notification {
  id          String            @id @default(cuid())
  userClerkId String            @map("user_clerk_id")
  type        NotificationType
  title       String
  message     String
  data        Json?
  read        Boolean           @default(false)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  // already CASCADE in your DB screenshot
  user User @relation(fields: [userClerkId], references: [clerkId], onDelete: Cascade, onUpdate: Cascade)

  @@map("notifications")
  @@index([userClerkId])
  @@index([read])
  @@index([createdAt])
}

model Expense {
  id             String          @id @default(cuid())
  tripId         String          @map("trip_id")
  paidByClerkId  String          @map("paid_by_clerk_id")
  amount         Decimal         @db.Decimal(10, 2)
  description    String
  category       ExpenseCategory @default(MISCELLANEOUS)
  merchantName   String?         @map("merchant_name")
  merchantUPI    String?         @map("merchant_upi")
  transactionId  String?         @map("transaction_id")
  paymentMethod  String?         @map("payment_method")
  screenshotUrl  String?         @map("screenshot_url")
  ocrData        Json?           @map("ocr_data")
  splitMethod    SplitMethod     @default(EQUAL)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  trip   Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  // ✅ CASCADE (this is the one currently throwing the error in your DB)
  paidBy User @relation(fields: [paidByClerkId], references: [clerkId], onDelete: Cascade)

  splits ExpenseSplit[]
  photos TripPhoto[]

  @@map("expenses")
  @@index([tripId])
  @@index([paidByClerkId])
  @@index([createdAt])
}

model ExpenseSplit {
  id         String   @id @default(cuid())
  expenseId  String   @map("expense_id")
  userClerkId String  @map("user_clerk_id")
  amount     Decimal  @db.Decimal(10, 2)
  settled    Boolean  @default(false)
  settledAt  DateTime? @map("settled_at")

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  // already CASCADE in your DB screenshot
  user    User    @relation(fields: [userClerkId], references: [clerkId], onDelete: Cascade)

  @@unique([expenseId, userClerkId])
  @@map("expense_splits")
  @@index([expenseId])
  @@index([userClerkId])
  @@index([settled])
}

model TripPhoto {
  id                String    @id @default(cuid())
  tripId            String    @map("trip_id")
  uploadedByClerkId String    @map("uploaded_by_clerk_id")
  imageUrl          String    @map("image_url")
  caption           String?
  location          String?
  date              DateTime?
  expenseId         String?   @map("expense_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  // ✅ CASCADE
  uploadedBy User     @relation(fields: [uploadedByClerkId], references: [clerkId], onDelete: Cascade)

  expense    Expense? @relation(fields: [expenseId], references: [id])

  @@map("trip_photos")
  @@index([tripId])
  @@index([uploadedByClerkId])
  @@index([expenseId])
  @@index([date])
}

enum TripStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

enum UserRole {
  HANDLER
  MEMBER
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum JoinMethod {
  CREATED
  INVITE_CODE
  INVITE_LINK
  REQUEST
  INVITATION
  UNKNOWN
}

enum NotificationType {
  MEMBER_REMOVED
  TRIP_DELETED
  REQUEST_ACCEPTED
  REQUEST_REJECTED
  MEMBER_JOINED
  EXPENSE_ADDED
  EXPENSE_SETTLED
}

enum ExpenseCategory {
  FOOD
  TRANSPORT
  ACCOMMODATION
  ACTIVITIES
  SHOPPING
  MEDICAL
  MISCELLANEOUS
}

enum SplitMethod {
  EQUAL
  CUSTOM
  PERCENTAGE
}